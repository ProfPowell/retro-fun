<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} — {% endif %}{{ site.name }}</title>
{% set pageTitle = title if title else site.name %}
{% set pageDesc = description if description else site.description %}
{% set pageImage = (site.url + image) if image else (site.url + site.ogImage) %}
{% set pageUrl = site.url + page.url %}
<meta name="description" content="{{ pageDesc }}">
<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ pageDesc }}">
<meta property="og:image" content="{{ pageImage }}">
<meta property="og:url" content="{{ pageUrl }}">
<meta property="og:site_name" content="{{ site.name }}">
<!-- Twitter / Mastodon Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ pageTitle }}">
<meta name="twitter:description" content="{{ pageDesc }}">
<meta name="twitter:image" content="{{ pageImage }}">
<link rel="stylesheet" href="{{ '/css/theme.css' | url }}">
<link rel="stylesheet" href="{{ '/css/nav.css' | url }}">
<link rel="stylesheet" href="{{ '/css/cards.css' | url }}">
<link rel="stylesheet" href="{{ '/css/previews.css' | url }}">
<link rel="stylesheet" href="{{ '/css/post.css' | url }}">
</head>
<body>

<header>
  <h1><a href="{{ '/' | url }}">{{ site.name }}</a></h1>
  <p class="subtitle">{{ site.subtitle | safe }}</p>
</header>

<nav class="site-nav">
  <a href="{{ '/' | url }}"{% if page.url == '/' %} aria-current="page"{% endif %}>Latest</a>
  <a href="{{ '/demos/' | url }}"{% if page.url == '/demos/' %} aria-current="page"{% endif %}>Demos</a>
  <a href="{{ '/posts/' | url }}"{% if page.url == '/posts/' %} aria-current="page"{% endif %}>Posts</a>
  <a href="{{ '/about/' | url }}"{% if page.url == '/about/' %} aria-current="page"{% endif %}>About</a>
</nav>

{{ content | safe }}

<footer>
  <p>Zero dependencies &bull; Pure HTML/CSS/JS &bull; Vibe coded with stealth</p>
</footer>

</body>
</html>
